# Copy to .env and fill in. Required vars panic at startup if missing.

# External LLM (Groq-compatible chat completions)
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_API_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Local embeddings (fastembed / BGE-M3, in-process — no external service)
EMBED_CACHE_DIR=./models            # optional (default shown) — ONNX model cache dir
EMBED_THREADS=16                    # optional (default shown) — ONNX intra-op CPU threads

# Auth / JWT  (RS256 — generate a keypair via GET /v1/gen_rsa_keypair)
JWT_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_SECRET=change-me
JWT_ACCESS_EXPIRATION_MINUTES=15    # optional (default 15)
JWT_REFRESH_EXPIRATION_DAYS=7       # optional (default 7)
VERIFICATION_TOKEN_EXPIRY_HOURS=24  # optional (default 24)
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1 # optional (default 1)

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:password@localhost:5432/aulidb
POSTGRES_USER=postgres              # optional

# Vector store (in-process; directory holding the per-collection JSON files)
VECTOR_DB_PATH=./vectors            # optional (default shown)
